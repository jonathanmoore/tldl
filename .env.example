# Transport mode: "stdio" (local dev, default) or "http" (LAN / Tailscale).
# - stdio: Claude Code spawns the process, no auth, no port. Default and
#   recommended path; no env vars required.
# - http: Uvicorn serves on $PORT with bearer-token auth. Intended for
#   exposing the server on your LAN or over Tailscale to other devices.
#   Cloud/datacenter hosting is not supported (YouTube blocks those IPs).
TLDL_TRANSPORT=stdio

# Required when TLDL_TRANSPORT=http. Not needed for local stdio.
# Bearer token clients must send as `Authorization: Bearer <token>`.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_BEARER_TOKEN=

# Optional: server log level. Default INFO.
LOG_LEVEL=INFO

# Optional: HTTP listen port (only used in http mode). Default 8000.
PORT=8000
