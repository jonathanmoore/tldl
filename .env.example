# Transport mode: "stdio" (local dev, default) or "http" (Railway/remote).
# - stdio: Claude Code spawns the process, no auth, no port. No bearer token
#   or Webshare credentials required.
# - http: Uvicorn serves on $PORT with bearer-token auth (StaticTokenVerifier).
TLDL_TRANSPORT=stdio

# Required when TLDL_TRANSPORT=http (Railway). Not needed for local stdio.
# Bearer token clients must send as `Authorization: Bearer <token>`.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_BEARER_TOKEN=

# Required for Railway / cloud hosting. YouTube blocks transcript requests from
# datacenter IPs; use Webshare residential proxies (https://www.webshare.io).
# Locally these can be left blank — direct connection works from a residential IP.
WEBSHARE_PROXY_USERNAME=
WEBSHARE_PROXY_PASSWORD=

# Optional: comma-separated 2-letter country codes to filter Webshare exit IPs.
# Example: us,de
WEBSHARE_PROXY_LOCATIONS=

# Optional: server log level. Default INFO.
LOG_LEVEL=INFO

# Local dev only. Railway injects PORT automatically. Only used in http mode.
PORT=8000
